# Секретный ключ Django (сгенерируйте новый для продакшна: https://djecrety.ir/)
SECRET_KEY=your-secret-key-here

# Режим отладки (True для разработки, False для продакшна)
DEBUG=True

# Разрешённые хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1

# Настройки базы данных
# Оставьте пустым для использования SQLite (локальная разработка)
# Заполните для использования PostgreSQL (Docker/Продакшн)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Настройки почты (SMTP)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Wlib
